# =====================================================================
# Advanced Web Search configuration — EVERYTHING here is OPTIONAL.
# Advanced Web Search runs with ZERO keys out of the box (keyless web + academic
# sources, and a local Ollama model if one is detected).
# Copy this file to `.env` and fill in only what you want to enable.
# =====================================================================

# ---------------------------------------------------------------------
# LLM PROVIDERS (optional — add a key to upgrade quality automatically)
# Advanced Web Search auto-detects which keys are present and routes accordingly.
# Priority when present: Anthropic > OpenAI > Gemini > Groq > DeepSeek
# If none present, it falls back to local Ollama.
# ---------------------------------------------------------------------
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GEMINI_API_KEY=
# GROQ_API_KEY=
# DEEPSEEK_API_KEY=
# OPENROUTER_API_KEY=

# ---------------------------------------------------------------------
# LOCAL MODELS (Ollama). Default base url shown; change only if custom.
# Install Ollama from https://ollama.com to enable fully-offline mode.
# ---------------------------------------------------------------------
# AWSEARCH_OLLAMA_BASE_URL=http://localhost:11434
# Force a specific default local model (otherwise auto-picked from RAM):
# AWSEARCH_LOCAL_MODEL=qwen3:8b

# ---------------------------------------------------------------------
# OPTIONAL SEARCH UPGRADES (keyless sources work without any of these)
# ---------------------------------------------------------------------
# TAVILY_API_KEY=             # managed web search, 1k free credits/mo
# BRAVE_API_KEY=              # Brave Search API, independent web index
# AWSEARCH_SEARXNG_URL=         # self-hosted SearXNG instance, e.g. http://localhost:8080
# OPENALEX_API_KEY=           # free key, unlocks citation-graph ranking signals
# CORE_API_KEY=               # free key, OA aggregator with full-text downloads
# AWSEARCH_CONTACT_EMAIL=       # polite-pool email for Crossref/Unpaywall/OpenAlex
# SEMANTIC_SCHOLAR_API_KEY=   # higher rate limits + TLDRs

# ---------------------------------------------------------------------
# SERVER / STORAGE
# ---------------------------------------------------------------------
# AWSEARCH_HOST=127.0.0.1
# AWSEARCH_PORT=8787
# AWSEARCH_DATA_DIR=./data       # SQLite db + caches + model cache live here
# AWSEARCH_LOG_LEVEL=info
